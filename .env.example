DATABASE_URL=postgresql://mydoglog:password@localhost:5433/mydoglog
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3847
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3847
CRON_SECRET=

# Production overrides (set on VPS in /root/mydoglog/.env):
# POSTGRES_PASSWORD=<strong-password>
# BETTER_AUTH_SECRET=<openssl rand -base64 32>
# BETTER_AUTH_URL=https://mydoglog.ca
# NEXT_PUBLIC_BETTER_AUTH_URL=https://mydoglog.ca
# CRON_SECRET=<must match GitHub Actions secret>
